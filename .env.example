# RetailFlow AI — environment variables
# Copy this to .env and fill in your values

# NVIDIA NIM API key (required for LLM agents)
# Get yours at: https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-your-key-here

# JWT secret (change this in production — use: openssl rand -hex 32)
SECRET_KEY=changeme-use-a-long-random-string

# SQLite database path (relative to project root)
DATABASE_URL=sqlite:///data/retailflow.db
DB_PATH=data/retailflow.db

# FAISS vector index path
FAISS_INDEX_PATH=data/faiss_index

# Knowledge-base documents directory (txt + pdf supported)
PDF_DIR=data/pdfs

# CORS — comma-separated origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:8501

# Streamlit target API (when running Streamlit separately)
API_BASE_URL=http://localhost:8000
