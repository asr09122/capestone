# ── Data directory is fully committed ────────────────────────────────────────
# DB, FAISS index, and PDFs are all pushed to git and baked into the Docker image.
# Only exclude SQLite WAL/SHM journal files (temporary, created at runtime).
data/*.db-shm
data/*.db-wal
tests/
scripts/run_tests.py
scripts/generate_report.py
scripts/seed_test_data.py

